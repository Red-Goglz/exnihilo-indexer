modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Start Indexer"

[[workflows.workflow]]
name = "Start Indexer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm start"
waitForPort = 42069

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 42069
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install"]
run = ["sh", "-c", "npm start"]
